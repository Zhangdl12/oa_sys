APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_FILE_ENABLED=false

MYSQL_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=oa_user
MYSQL_PASSWORD=oa_password
MYSQL_DATABASE=oa
MYSQL_MIN_SIZE=1
MYSQL_MAX_SIZE=10

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=
RBAC_CACHE_TTL_SECONDS=1800

HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20

CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
SCHEDULE_TRIGGER_TOKEN=change-me-schedule-token

FEISHU_ENABLED=false
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOURLY_NOTIFY_ENABLED=false
FEISHU_HOURLY_NOTIFY_USER_ID=
USER_CREATE_NOTIFY_ENABLED=false
USER_CREATE_NOTIFY_RECEIVE_ID_TYPE=chat_id
USER_CREATE_NOTIFY_RECEIVE_ID=
PERMISSION_NOTIFY_ENABLED=false
PERMISSION_NOTIFY_RECEIVE_ID_TYPE=user_id
PERMISSION_NOTIFY_RECEIVE_ID=
ROLE_NOTIFY_ENABLED=false
ROLE_NOTIFY_RECEIVE_ID_TYPE=user_id
ROLE_NOTIFY_RECEIVE_ID=

JWT_SECRET_KEY=local-dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
